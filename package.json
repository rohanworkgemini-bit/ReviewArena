{
  "name": "reviewarena",
  "version": "0.1.0",
  "private": true,
  "description": "Benchmarking automated peer review systems via human pairwise comparison and Elo ranking. Thesis project, UKP Lab, TU Darmstadt.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "mprocs",
    "dev:clean": "for p in 8000 8001 5173; do pid=$(lsof -ti :$p 2>/dev/null); [ -n \"$pid\" ] && kill -9 $pid && echo \"killed $pid on :$p\" || echo \":$p already free\"; done",
    "dev:review-gen": "services/review-gen/.venv/bin/python -m uvicorn app.main:app --reload --port 8001 --app-dir services/review-gen --reload-dir services/review-gen/app",
    "dev:api": "pnpm --filter @reviewarena/api dev",
    "dev:web": "pnpm --filter @reviewarena/web dev",
    "dev:js": "pnpm -r --parallel --filter ./apps/* run dev",
    "build": "pnpm -r --filter ./apps/* --filter ./packages/* run build",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "db:up": "docker compose up -d postgres",
    "stack:up": "docker compose up -d"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  },
  "packageManager": "pnpm@9.7.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
