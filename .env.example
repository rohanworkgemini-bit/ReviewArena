# Copy to .env and fill in. NEVER commit the real .env.
#
# Strong-secret fields below require `openssl rand -hex 32`.
# Rotation playbook: see docs/SECRETS.md

# --- apps/api ---
DATABASE_URL="postgresql://reviewarena:reviewarena@localhost:5432/reviewarena?schema=public"
API_PORT=8000

# Bearer token for /admin/* endpoints. 32+ chars random.
#   openssl rand -hex 32
ADMIN_TOKEN=""

# HMAC key for pair-tokens. MUST be different from ADMIN_TOKEN so
# rotating one doesn't invalidate the other.
#   openssl rand -hex 32
PAIR_TOKEN_SECRET=""

# CORS whitelist — the browser app's origin. Comma-separated for
# multiple environments (e.g. "http://localhost:5173,https://reviewarena.example").
WEB_ORIGIN="http://localhost:5173"

REVIEW_GEN_URL="http://localhost:8001"

# Bearer key the Node API sends as `X-API-Key` to the Python service.
# MUST match REVIEW_GEN_API_KEY on the Python side (services/review-gen).
# REQUIRED in production — without it the Python service runs in OPEN mode
# and any internet caller can spend your LLM budget via /generate.
#   openssl rand -hex 32
REVIEW_GEN_API_KEY=""

# --- apps/web ---
VITE_API_URL="http://localhost:8000"

# --- services/review-gen ---
# Same value as REVIEW_GEN_API_KEY above. The Python service rejects
# requests without a matching X-API-Key header (set this AND apps/api's
# REVIEW_GEN_API_KEY to the same value).
REVIEW_GEN_API_KEY=""

# Production gate. Set to "production" in Cloud Run / your deploy env.
# When production=true and REVIEW_GEN_API_KEY is empty, the Python
# service REFUSES to boot — protects against accidental open-mode in
# prod (which would let any internet caller drain your LLM budget).
# Leave empty / unset for local dev (open mode permitted there).
REVIEWARENA_ENV=""

# arXiv parser base URL. Defaults to our self-hosted Cloud Run instance
# (services/cloudrun/arxiv2md/). Override only if you redeploy or want to
# flip back to the public arxiv2md.org (currently offline as of 2026-06-27).
# ARXIV2MD_BASE="https://reviewarena-arxiv2md-554348820688.europe-west3.run.app"

# PDF parser: Datalab's hosted Chandra OCR-2 API. Get a key at
# https://www.datalab.to → paste it here. All /parse calls go through
# this endpoint (no self-hosted parser).
CHANDRA_API_KEY=""
# Model adapter URLs (deploy the matching services/*-modal service, then
# paste the printed Modal URL here). A specialist system stays DISABLED in
# the DB until its URL is set, so pair selection won't pick a system that
# can't respond.
DEEPREVIEWER_URL=""
OPENREVIEWER_URL=""
# Optional extra specialist review models:
CYCLEREVIEWER_URL=""   # services/cyclereviewer-modal (gated HF repo)
SEA_URL=""             # services/sea-modal (apache-2.0)

# Frontier-LLM zero-shot baselines via the generic openai-compat adapter.
# Each system is enabled only when its key is present.
DEEPSEEK_API_KEY=""    # enables the deepseek-v3 system (api.deepseek.com)
OPENROUTER_API_KEY=""  # enables claude-sonnet (and any OpenRouter model)
# Note: gpt-4o reuses OPENAI_API_KEY below; gpt-5-mini/gemini already wired.

# Shared secret used by the Python service to authenticate to the
# Modal-hosted review LLMs (DeepReviewer, OpenReviewer). MUST match
# the value of the `modal-shared-auth` Modal secret on the server side.
# Create both with:
#   openssl rand -hex 32                              # generates the value
#   modal secret create modal-shared-auth MODAL_SHARED_SECRET=<value>
MODAL_SHARED_SECRET=""

# LLM API keys for the GPT/Gemini adapters and the judge.
OPENAI_API_KEY=""
GEMINI_API_KEY=""

# HuggingFace token (read-only) for gated model downloads on Modal.
# Also create the Modal secret with the same value:
#   modal secret create hf-token HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx
HF_TOKEN=""
