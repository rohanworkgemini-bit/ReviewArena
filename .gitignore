# editor / OS
.DS_Store
**/.DS_Store
.idea/
.vscode/
*.swp

# data — we never persist PDFs to disk
uploads/
*.sqlite
*.db

# stray screenshots in repo root (move to docs/images/ if you want to keep one)
/*.png
/*.jpg
/*.jpeg

# old prototypes that lived under research/
research/_legacy_uploads/
research/_legacy_env/

# prisma generated client (regenerated on install)
apps/api/prisma/generated/

# workflow + agent transcripts (local Claude sessions)
.claude/projects/
